                </div>
                <div>
                    <h1>Bebida X</h1>
                    <p>Categoria</p>
                </div>
                <h2>R$40,99</h2>
                <div class="buttons">
                    <button class="market-button">Adicionar ao carrinho</button>
                    <a href="#" class="details-button">Ver detalhes</a>
                </div>
            </li>

            <li class="product-card page-anim-prep">
                <div class="product-img">
                    <img src="~/img/ExemploBebida.png" alt="Bebida X">
                </div>
                <div>
                    <h1>Bebida X</h1>
                    <p>Categoria</p>
                </div>
                <h2>R$40,99</h2>
                <div class="buttons">
                    <button class="market-button">Adicionar ao carrinho</button>
                    <a href="#" class="details-button">Ver detalhes</a>
                </div>
            </li>

            <li class="product-card page-anim-prep">
                <div class="product-img">
                    <img src="~/img/ExemploBebida.png" alt="Bebida X">
                </div>
                <div>
                    <h1>Bebida X</h1>
                    <p>Categoria</p>
                </div>
                <h2>R$40,99</h2>
                <div class="buttons">
                    <button class="market-button">Adicionar ao carrinho</button>
                    <a href="#" class="details-button">Ver detalhes</a>
                </div>
            </li>

        </ul>
    </div>
</section>


@section Scripts {
    <script src="~/js/cart.js"></script>
    <script src="~/js/catalogo.js"></script>
    <script src="~/js/animations.js"></script>
}
