@{
    ViewData["Title"] = "Catálogo - Valhalla Bebidas";
}

@section Styles {
    <link rel="stylesheet" href="~/css/catalogo.css" />
    <link rel="stylesheet" href="~/css/page-animations.css" />

    <style>
        .product-card,
        .page-anim-prep {
            opacity: 1 !important;
            visibility: visible !important;
            transform: none !important;
        }
    </style>
}

<header class="catalogoHero">
    <section class="imgSection page-anim-prep">
        <!-- tenta carregar a imagem real; se falhar, mostra fallback SVG -->
        <img src="~/img/assets/categoriaPhoto.jpg" alt="Imagem Valhalla" 
             onerror="this.style.display='none'; document.getElementById('categoriaFallback').style.display='block';" />

        <div id="categoriaFallback" style="display:none;">
            <svg width="100%" height="340" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Imagem Valhalla">
                <defs>
                    <linearGradient id="g" x1="0" x2="1">
                        <stop stop-color="#f5f5f7" offset="0" />
                        <stop stop-color="#e6e7ea" offset="1" />
                    </linearGradient>
                </defs>
                <rect width="100%" height="100%" fill="url(#g)" />
                <text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" font-size="28" fill="#777">Imagem Valhalla</text>
            </svg>
        </div>
    </section>
</header>

<section class="category">
    <div class="filter-container page-anim-prep">
        <div class="filter">
            <h3>CATEGORIAS</h3>
            <!-- Ajuste semântico: transformar cards em <ul> -->
            <ul class="cards categorias">
                <li class="catalogo_filter-btn-active">
                    <button type="button" data-categoria-id="todos">Todos</button>
                </li>
                <li class="catalogo_filter-btn">
                    <button type="button" data-categoria-id="1">Refrigerantes</button>
                </li>
                <li class="catalogo_filter-btn">
                    <button type="button" data-categoria-id="2">Destilados</button>
                </li>
                <li class="catalogo_filter-btn">
                    <button type="button" data-categoria-id="3">Cervejas</button>
                </li>
                <li class="catalogo_filter-btn">
                    <button type="button" data-categoria-id="4">Energéticos</button>
                </li>
                <li class="catalogo_filter-btn">
                    <button type="button" data-categoria-id="5">Águas</button>
                </li>
                <li class="catalogo_filter-btn">
                    <button type="button" data-categoria-id="6">Sucos</button>
                </li>
                <li class="catalogo_filter-btn">
                    <button type="button" data-categoria-id="7">Vinhos</button>
                </li>
                <li class="catalogo_filter-btn">
                    <button type="button" data-categoria-id="8">Gelos</button>
                </li>
            </ul>

            <h3>ORDENAR POR</h3>
            <ul class="cards ordenacao">
                <li class="catalogo_filter-btn-active">
                    <button type="button" data-ordem="relevancia">Relevância</button>
                </li>
                <li class="catalogo_filter-btn">
                    <button type="button" data-ordem="menor">Menor preço</button>
                </li>
                <li class="catalogo_filter-btn">
                    <button type="button" data-ordem="maior">Maior preço</button>
                </li>
                <li class="catalogo_filter-btn">
                    <button type="button" data-ordem="nome">Nome A-Z</button>
                </li>
            </ul>
        </div>
    </div>

    <div class="products-container">
        <div class="product__title page-anim-prep">
            <div>
                <h1>Catálogo</h1>
                <p>0 produtos encontrados</p>
            </div>

            <label for="search-input">
                <a href="#">
                    <img src="~/img/Icons/Glass.svg" alt="Buscar">
                </a>
                <input type="text" id="search-input" placeholder="Buscar produtos">
            </label>
        </div>

        <!-- ==========================================
           NOVA ESTRUTURA GRID (Sem .line e usando <ul>)
           ========================================== -->
        <ul class="products">

            <li class="product-card page-anim-prep">
                <div class="product-img">
                    <img src="~/img/ExemploBebida.png" alt="Bebida X">
                </div>
                <div>
                    <h1>Bebida X</h1>
                    <p>Categoria</p>
                </div>
                <h2>R$40,99</h2>
                <div class="buttons">
                    <button class="market-button">Adicionar ao carrinho</button>
                    <a href="#" class="details-button">Ver detalhes</a>
                </div>
            </li>

            <li class="product-card page-anim-prep">
                <div class="product-img">
                    <img src="~/img/ExemploBebida.png" alt="Bebida X">
                </div>
                <div>
                    <h1>Bebida X</h1>
                    <p>Categoria</p>
                </div>
                <h2>R$40,99</h2>
                <div class="buttons">
                    <button class="market-button">Adicionar ao carrinho</button>
                    <a href="#" class="details-button">Ver detalhes</a>
                </div>
            </li>

